[Unit]
Description=Sidewalk Web Demo
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/ncs/sdks/ncs-sdk-sidewalk/sdk-sidewalk/tools/web_demo
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/ncs/sdks/ncs-sdk-sidewalk/sdk-sidewalk/tools/web_demo/.venv/bin/gunicorn --bind 0.0.0.0:8000 --worker-class gthread --threads 8 --timeout 0 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
